/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model booking_travelers {
  traveler_id   Int       @id @default(autoincrement())
  booking_id    Int
  full_name     String    @db.VarChar(150)
  dob           DateTime? @db.Date
  gender        String    @db.VarChar(10)
  id_number     String?   @db.VarChar(12)
  traveler_type String    @default("adult") @db.VarChar(20)
  created_at    DateTime  @default(now()) @db.Timestamp(6)
  bookings      bookings  @relation(fields: [booking_id], references: [booking_id], onDelete: NoAction, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bookings {
  booking_id        Int                 @id @default(autoincrement())
  user_id           Int
  tour_schedule_id  Int
  contact_name      String              @db.VarChar(150)
  contact_phone     String              @db.VarChar(15)
  contact_email     String              @db.VarChar(150)
  adult_count       Int                 @default(1)
  child_count       Int                 @default(0)
  infant_count      Int                 @default(0)
  adult_unit_price  Decimal             @default(0) @db.Decimal(12, 2)
  child_unit_price  Decimal             @default(0) @db.Decimal(12, 2)
  infant_unit_price Decimal             @default(0) @db.Decimal(12, 2)
  total_amount      Decimal             @default(0) @db.Decimal(12, 2)
  status            String              @default("pending") @db.VarChar(50)
  note              String?
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  booking_travelers booking_travelers[]
  tour_schedules    tour_schedules      @relation(fields: [tour_schedule_id], references: [tour_schedule_id], onDelete: NoAction, onUpdate: NoAction)
  users             users               @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)
  payments          payments[]

  @@index([tour_schedule_id], map: "idx_bookings_schedule")
  @@index([user_id], map: "idx_bookings_user")
}

model destinations_detail {
  detail_id   Int       @id @default(autoincrement())
  location_id Int       @unique
  latitude    Decimal?  @db.Decimal(10, 6)
  longitude   Decimal?  @db.Decimal(10, 6)
  best_time   String?   @db.VarChar(255)
  tags        String?
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @db.Timestamp(6)
  locations   locations @relation(fields: [location_id], references: [location_id], onDelete: NoAction, onUpdate: NoAction)
}

model favorites {
  user_id    Int
  tour_id    Int
  created_at DateTime @default(now()) @db.Timestamp(6)
  tours      tours    @relation(fields: [tour_id], references: [tour_id], onDelete: NoAction, onUpdate: NoAction)
  users      users    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([user_id, tour_id])
}

model geographic_levels {
  level_id    Int         @id @default(autoincrement())
  name        String      @unique @db.VarChar(50)
  description String?
  created_at  DateTime    @default(now()) @db.Timestamp(6)
  updated_at  DateTime    @default(now()) @db.Timestamp(6)
