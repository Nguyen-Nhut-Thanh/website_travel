model locations {
  location_id         Int                  @id @default(autoincrement())
  name                String               @unique @db.VarChar(255)
  level_id            Int
  parent_id           Int?
  country_code        String?              @db.VarChar(10)
  note                String?
  created_at          DateTime             @default(now()) @db.Timestamp(6)
  updated_at          DateTime             @default(now()) @db.Timestamp(6)
  destinations_detail destinations_detail?
  hotels              hotels[]
  location_images     location_images[]
  geographic_levels   geographic_levels    @relation(fields: [level_id], references: [level_id], onDelete: NoAction, onUpdate: NoAction)
  locations           locations?           @relation("locationsTolocations", fields: [parent_id], references: [location_id], onDelete: NoAction, onUpdate: NoAction)
  other_locations     locations[]          @relation("locationsTolocations")
  tour_destinations   tour_destinations[]
  tours               tours[]

  @@index([level_id], map: "idx_locations_level")
  @@index([parent_id], map: "idx_locations_parent")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model location_images {
  image_id    Int       @id @default(autoincrement())
  location_id Int
  image_url   String
  is_cover    Int       @default(0) @db.SmallInt
  sort_order  Int       @default(1)
  alt_text    String?   @db.VarChar(255)
  status      Int       @default(1) @db.SmallInt
  created_at  DateTime  @default(now()) @db.Timestamp(6)
  updated_at  DateTime  @default(now()) @db.Timestamp(6)
  locations   locations @relation(fields: [location_id], references: [location_id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([location_id, sort_order], map: "uq_location_images_sort")
  @@index([location_id], map: "idx_location_images_location")
  @@index([is_cover], map: "idx_location_images_cover")
  @@index([status], map: "idx_location_images_status")
}

