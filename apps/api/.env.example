## Public URLs and CORS
API_PUBLIC_URL=https://api.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://example.com,https://www.example.com
FRONTEND_PUBLIC_URL=https://example.com

## Server runtime
HOST=0.0.0.0
PORT=4000

## PostgreSQL database
DATABASE_URL=postgresql://username:password@localhost:5432/travel_v2?schema=public

## MongoDB database
MONGODB_URL=mongodb://localhost:27017/travel_v2
MONGO_DB_NAME=travel_v2

## JWT authentication
JWT_EXPIRES_IN=86400
JWT_SECRET=replace_with_a_long_random_secret

## Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

## SMTP mail delivery
MAIL_FROM_EMAIL=you@example.com
MAIL_FROM_NAME=Travel V2
MAIL_HOST=smtp.gmail.com
MAIL_PASS=your_smtp_password_or_app_password
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=you@example.com

## Cloudinary media storage
CLOUDINARY_KEY=your_cloudinary_key
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_SECRET=your_cloudinary_secret

## VNPay payment gateway
VNP_HASH_SECRET=your_vnpay_hash_secret
VNP_TMN_CODE=your_vnpay_tmn_code
